# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (must match docker-compose.yml)
POSTGRES_DB=djllm
POSTGRES_USER=djllm
POSTGRES_PASSWORD=djllm
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# LangGraph checkpointer (defaults to the Postgres settings above if unset)
# CHECKPOINTER_DSN=postgresql://djllm:djllm@127.0.0.1:5433/djllm
