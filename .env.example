# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (must match compose.yaml)
POSTGRES_DB=djllm
POSTGRES_USER=djllm
POSTGRES_PASSWORD=djllm
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120        # seconds per model request

# LangGraph checkpointer (defaults to the Postgres settings above if unset)
# CHECKPOINTER_DSN=postgresql://djllm:djllm@127.0.0.1:5433/djllm

# Observability (all optional)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# LangSmith tracing is read directly by LangChain from these env vars:
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
